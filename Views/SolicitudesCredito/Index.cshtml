@model ParcialProgramacion1.ViewModels.SolicitudFiltroViewModel
@using ParcialProgramacion1.Models

@{
    ViewData["Title"] = "Mis solicitudes";
}

<h1>Mis solicitudes</h1>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-3">
            <label asp-for="Estado" class="form-label">Estado</label>
            <select asp-for="Estado" class="form-control">
                <option value="">Todos</option>
                <option value="Pendiente">Pendiente</option>
                <option value="Aprobado">Aprobado</option>
                <option value="Rechazado">Rechazado</option>
            </select>
            <span asp-validation-for="Estado" class="text-danger"></span>
        </div>

        <div class="col-md-2">
            <label asp-for="MontoMin" class="form-label">Monto mínimo</label>
            <input asp-for="MontoMin" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="MontoMin" class="text-danger"></span>
        </div>

        <div class="col-md-2">
            <label asp-for="MontoMax" class="form-label">Monto máximo</label>
            <input asp-for="MontoMax" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="MontoMax" class="text-danger"></span>
        </div>

        <div class="col-md-2">
            <label asp-for="FechaInicio" class="form-label">Fecha inicio</label>
            <input asp-for="FechaInicio" class="form-control" type="date" />
            <span asp-validation-for="FechaInicio" class="text-danger"></span>
        </div>

        <div class="col-md-2">
            <label asp-for="FechaFin" class="form-label">Fecha fin</label>
            <input asp-for="FechaFin" class="form-control" type="date" />
            <span asp-validation-for="FechaFin" class="text-danger"></span>
        </div>

        <div class="col-md-1 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Filtrar</button>
        </div>
    </div>
</form>

@if (!Model.Solicitudes.Any())
{
    <div class="alert alert-info">
        No se encontraron solicitudes.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Monto solicitado</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Ingresos mensuales</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var solicitud in Model.Solicitudes)
            {
                <tr>
                    <td>@solicitud.Id</td>
                    <td>S/ @solicitud.MontoSolicitado.ToString("N2")</td>
                    <td>@solicitud.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                    <td>@solicitud.Estado</td>
                    <td>S/ @solicitud.Cliente?.IngresosMensuales.ToString("N2")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@solicitud.Id" class="btn btn-sm btn-info">
                            Detalle
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}