@model ParcialProgramacion1.Models.SolicitudCredito

@{
    ViewData["Title"] = "Detalle de solicitud";
}

<h1>Detalle de solicitud</h1>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Solicitud #@Model.Id</h5>

        <p><strong>Cliente ID:</strong> @Model.ClienteId</p>
        <p><strong>Ingresos mensuales:</strong> S/ @Model.Cliente?.IngresosMensuales.ToString("N2")</p>
        <p><strong>Monto solicitado:</strong> S/ @Model.MontoSolicitado.ToString("N2")</p>
        <p><strong>Fecha de solicitud:</strong> @Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Estado:</strong> @Model.Estado</p>

        @if (!string.IsNullOrWhiteSpace(Model.MotivoRechazo))
        {
            <p><strong>Motivo de rechazo:</strong> @Model.MotivoRechazo</p>
        }
        else
        {
            <p><strong>Motivo de rechazo:</strong> No aplica</p>
        }
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Volver</a>